        "currency_symbol": "^[₹ரூ]|^Rs\\.?|^INR",
        "currency_strip": "^[₹ரூRsINR.\\s]+",
        "cardinal": "^\\d+$",
        "ordinal": "^(\\d+)(st|nd|rd|th|வது|ஆம்)$",
        "unit": "^(\\d+(?:\\.\\d+)?)\\s*(kg|g|mg|km|m|cm|mm|mi|ft|in|l|ml|kl|°C|°F|K|kmph|mph|m/s|Hz|kHz|MHz|GHz|W|kW|MW|V|A|KB|MB|GB|TB)$"
    },
